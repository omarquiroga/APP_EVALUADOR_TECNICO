# Copiar a .env para valores locales.
AUTOMATION_HOST=127.0.0.1
AUTOMATION_PORT=8765
AUTOMATION_MCP_PATH=/mcp
AUTOMATION_DEFAULT_WORKSPACE=C:\PROYECTOS\Evaluador Tecnico LFVU
AUTOMATION_ALLOWED_WORKSPACES=C:\PROYECTOS\Evaluador Tecnico LFVU
AUTOMATION_STATE_DIR=
AUTOMATION_LOG_DIR=

# Si el alias "codex" no funciona en el equipo operador, usar la ruta completa.
CODEX_COMMAND=codex
CODEX_SANDBOX_MODE=workspace-write
CODEX_APPROVAL_POLICY=never

# Plantillas de comando. El servidor cita automaticamente los valores variables.
CODEX_START_TEMPLATE={codex_command} exec -C {workspace_path} -s {sandbox_mode} -c approval_policy={approval_policy} -o {output_path} -
CODEX_CONTINUE_TEMPLATE={codex_command} exec resume -C {workspace_path} -s {sandbox_mode} -c approval_policy={approval_policy} -o {output_path} {codex_session_id} -
CODEX_CONTINUE_FALLBACK_TEMPLATE={codex_command} exec resume -C {workspace_path} -s {sandbox_mode} -c approval_policy={approval_policy} -o {output_path} --last -
